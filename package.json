{
  "name": "flow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Standalone visual workspace built on Excalidraw with local, IndexedDB, and Google Drive storage.",
  "scripts": {
    "build:excalidraw": "cd vendor/excalidraw && yarn install --frozen-lockfile && yarn build:package",
    "predev": "node scripts/copy-excalidraw-fonts.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-excalidraw-fonts.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "npm run build && vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "file:vendor/excalidraw/packages/excalidraw",
    "@radix-ui/react-menubar": "^1.1.20",
    "idb": "^8.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
